{
  "entities": {
    "video": {
      "title": "Video Entity",
      "description": "Defines a video (anime or movie)",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "thumbnail": { "type": "string" },
        "videoUrl": { "type": "string" },
        "category": { "type": "string", "enum": ["anime", "movie"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "videoUrl", "category"]
    }
  },
  "firestore": {
    "/videos/{videoId}": {
      "schema": "video",
      "description": "A collection of videos (anime or movies)."
    }
  }
}
